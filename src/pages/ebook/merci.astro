---
import Layout from '../../layouts/Layout.astro'

const type = Astro.url.searchParams.get('type') ?? 'guide'
const isGuide = type === 'guide'
---

<Layout title="Merci ! - Votre demande a bien été prise en compte">
  <main class="flex min-h-screen items-center justify-center bg-gradient-to-br from-gray-50 via-white to-primary-50 px-4">
    <div class="mx-auto max-w-lg text-center">
      <!-- Ebook cover -->
      <div class="mx-auto mb-6">
        <img
          src="/images/ebook-daytrader.png"
          alt="Guide Bourses et Investissement Autonome - DayTrader Canada"
          class="mx-auto w-40 drop-shadow-xl sm:w-48"
          width="192"
          height="263"
          loading="eager"
        />
      </div>

      <!-- Success Icon -->
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
        <svg class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>

      {isGuide ? (
        <>
          <h1 class="text-3xl font-extrabold text-gray-900">
            Merci ! Votre guide est en route
          </h1>
          <p class="mt-4 text-lg text-gray-600">
            Vous allez recevoir votre guide gratuit par email dans les prochaines
            minutes. Pensez à vérifier votre dossier spam si vous ne le trouvez pas.
          </p>
          <div class="mt-8 rounded-xl bg-primary-50 p-6">
            <p class="text-sm font-medium text-primary-700">
              En attendant, vous pouvez aussi demander un
              <a href="/ebook#diagnostic" class="font-bold underline">diagnostic personnalisé gratuit</a>
              pour aller encore plus loin.
            </p>
          </div>
        </>
      ) : (
        <>
          <h1 class="text-3xl font-extrabold text-gray-900">
            Merci pour vos réponses
          </h1>
          <p class="mt-4 text-lg text-gray-600">
            Votre diagnostic est en cours d'analyse.
          </p>
          <p class="mt-4 text-lg text-gray-600">
            Une agente de notre service à la clientèle communiquera avec vous sous peu afin de vous proposer une rencontre sans engagement avec l'un de nos Conseillers en formation.
          </p>
          <div class="mt-8 rounded-xl bg-primary-50 p-6">
            <p class="text-sm font-medium text-primary-700">
              Cette rencontre nous permettra de compléter et valider votre diagnostic et de vous orienter vers un plan de formation et d'accompagnement structuré, adapté à votre profil et à vos objectifs.
            </p>
            <p class="mt-3 text-sm font-semibold text-primary-800">
              À très bientôt.
            </p>
          </div>
        </>
      )}

      <a
        href="/ebook"
        class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Retour à la page d'accueil
      </a>
    </div>
  </main>
</Layout>
