# Google Apps Script Web App URL (deployed from google-apps-script/Code.gs)
PUBLIC_SHEETS_ENDPOINT=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Brevo (Sendinblue) API Key - server-side only
BREVO_API_KEY=

# Zapier Webhook URL for diagnostic form submissions
PUBLIC_ZAPIER_DIAGNOSTIC_WEBHOOK=https://hooks.zapier.com/hooks/catch/717461/ukg1mnr/

# Meta Pixel ID (optional - gated behind Tarteaucitron consent)
PUBLIC_META_PIXEL_ID=
